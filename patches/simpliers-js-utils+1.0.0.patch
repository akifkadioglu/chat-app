+// Date-only formatter (companion to formatDateTime). Called as $formatDate(date, locale).
+export function formatDate(dateString, localeStringParam) {
+  if (!dateString) {
+    return '';
+  }
+  const date = new Date(dateString);
+  if (isNaN(date.getTime())) {
+    return '';
+  }
+  const locale = localeStringParam || (import.meta.client ? navigator.language : 'en-US');
+
+  return date.toLocaleDateString(locale, {
+    year: 'numeric',
+    month: 'long',
+    day: 'numeric',
+  });
+}
+
+// Compact social-count formatter (e.g. 12.3K, 1.2M). suffix = { thousand, million, billion }.
+// simpliers-nuxt-utils globalFormatters passes the per-locale suffix map.
+export function formatSocialCount(num, suffix, localeString = 'en-US') {
+  const value = Number(num);
+  if (num === null || num === undefined || isNaN(value)) {
+    return '0';
+  }
+  const s = suffix || { thousand: 'K', million: 'M', billion: 'B' };
+  const abs = Math.abs(value);
+  let divisor = 1;
+  let unit = '';
+  if (abs >= 1e9) {
+    divisor = 1e9;
+    unit = s.billion;
+  } else if (abs >= 1e6) {
+    divisor = 1e6;
+    unit = s.million;
+  } else if (abs >= 1e3) {
+    divisor = 1e3;
+    unit = s.thousand;
+  }
+  if (divisor === 1) {
+    return new Intl.NumberFormat(localeString).format(value);
+  }
+  const formatted = new Intl.NumberFormat(localeString, {
+    minimumFractionDigits: 0,
+    maximumFractionDigits: 1,
+  }).format(value / divisor);
+  return `${formatted}${unit}`;
+}
+
+// Relative time formatter. `strings` is a per-locale map of label functions provided by
+// simpliers-nuxt-utils globalFormatters (justNow, secondsAgo, ... yearsAgo, unknown).
+export function formatTimeAgo(date, strings) {
+  const unknown = () => (strings && strings.unknown ? strings.unknown() : '');
+  if (!date) {
+    return unknown();
+  }
+  const d = new Date(date);
+  if (isNaN(d.getTime())) {
+    return unknown();
+  }
+
+  const seconds = Math.floor((Date.now() - d.getTime()) / 1000);
+  if (seconds < 10) return strings.justNow();
+  if (seconds < 60) return strings.secondsAgo(seconds);
+
+  const minutes = Math.floor(seconds / 60);
+  if (minutes === 1) return strings.aMinuteAgo();
+  if (minutes < 60) return strings.minutesAgo(minutes);
+
+  const hours = Math.floor(minutes / 60);
+  if (hours === 1) return strings.anHourAgo();
+  if (hours < 24) return strings.hoursAgo(hours);
+
+  const days = Math.floor(hours / 24);
+  if (days === 1) return strings.aDayAgo();
+  if (days < 7) return strings.daysAgo(days);
+
+  const weeks = Math.floor(days / 7);
+  if (weeks === 1) return strings.aWeekAgo();
+  if (days < 30) return strings.weeksAgo(weeks);
+
+  const months = Math.floor(days / 30);
+  if (months === 1) return strings.aMonthAgo();
+  if (months < 12) return strings.monthsAgo(months);
+
+  const years = Math.floor(days / 365);
+  if (years === 1) return strings.aYearAgo();
+  return strings.yearsAgo(years);
+}
